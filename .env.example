# Local development convenience ONLY.
# If set, the Settings form's API-key field is PRE-FILLED during `pnpm dev`.
# This value is NEVER bundled into a production build (see src/llm/devKey.ts).
# In production this app is strictly BYOK — users paste their own key in the UI.
VITE_DEV_LLM_API_KEY=
VITE_DEV_LLM_BASE_URL=https://api.deepseek.com
VITE_DEV_LLM_MODEL=deepseek-v4-flash
